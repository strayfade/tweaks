<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>items</key>
	<array>
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>LSText</string>
			<key>footerText</key>
			<string>Display a custom text line on the lock screen using the same rounded widget-like style and background.</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>defaults</key>
			<string>com.noah.lstext~prefs</string>
			<key>default</key>
			<true/>
			<key>key</key>
			<string>Enabled</string>
			<key>label</key>
			<string>Enable LSText</string>
		</dict>
		<dict>
			<key>key</key>
			<string>TextLine</string>
			<key>cell</key>
			<string>PSEditTextCell</string>
			<key>detail</key>
			<string>PSDetailController</string>
			<key>defaults</key>
			<string>com.noah.lstext~prefs</string>
			<key>default</key>
			<string>Welcome</string>
			<key>label</key>
			<string>Lock Screen Text</string>
			<key>placeholder</key>
			<string>Type custom text</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSSliderCell</string>
			<key>defaults</key>
			<string>com.noah.lstext~prefs</string>
