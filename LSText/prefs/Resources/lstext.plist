			<string>Horizontal Padding</string>
			<key>min</key>
			<real>10</real>
			<key>max</key>
			<real>30</real>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSButtonCell</string>
			<key>label</key>
			<string>Respring</string>
			<key>isDestructive</key>
			<true/>
			<key>action</key>
			<string>promptRespring</string>
		</dict>
