			<string>Vertical Offset</string>
			<key>min</key>
			<real>-260</real>
			<key>max</key>
			<real>-80</real>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSSliderCell</string>
			<key>defaults</key>
			<string>com.noah.lstext~prefs</string>
