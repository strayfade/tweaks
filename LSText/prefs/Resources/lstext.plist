			<real>0.95</real>
			<key>key</key>
			<string>TextOpacity</string>
			<key>label</key>
			<string>Opacity</string>
			<key>min</key>
			<real>0.2</real>
			<key>max</key>
			<real>1.0</real>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSSliderCell</string>
			<key>defaults</key>
			<string>com.noah.lstext~prefs</string>
