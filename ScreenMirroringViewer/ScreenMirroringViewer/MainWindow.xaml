<Window x:Class="ScreenMirroringViewer.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="Screen Mirroring"

        Icon="Resources/app.ico"

        Width="420"

        Height="922"

        MinWidth="280"

        MinHeight="620"

        WindowStartupLocation="CenterScreen"

        SizeChanged="MainWindow_SizeChanged"

        Background="Transparent"

        AllowsTransparency="True"

        WindowStyle="None"

        ResizeMode="CanResizeWithGrip"

        FontFamily="{StaticResource UIFont}"

        Focusable="True"

        PreviewKeyDown="Window_PreviewKeyDown"

        PreviewKeyUp="Window_PreviewKeyUp"

        PreviewTextInput="Window_PreviewTextInput"

        Loaded="MainWindow_Loaded"

        Closing="MainWindow_Closing"

        MouseMove="MainWindow_MouseMove"

        MouseLeave="MainWindow_MouseLeave">

    <Window.Resources>

        <Style x:Key="ChromeButtonStyle" TargetType="Button">

            <Setter Property="Width" Value="36"/>

            <Setter Property="Height" Value="28"/>

            <Setter Property="Margin" Value="2,0"/>

            <Setter Property="Background" Value="Transparent"/>

            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Foreground" Value="White"/>

            <Setter Property="FontSize" Value="12"/>

            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Root"

                                Background="{TemplateBinding Background}"

                                CornerRadius="6">

                            <ContentPresenter HorizontalAlignment="Center"

                                              VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter TargetName="Root" Property="Background" Value="#33FFFFFF"/>

                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">

                                <Setter TargetName="Root" Property="Background" Value="#55FFFFFF"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Geometry x:Key="HomeButtonIconGeometry">M12,3L4,9V20H9V13H15V20H20V9L12,3Z</Geometry>

        <Geometry x:Key="MenuButtonIconGeometry">M5,7H19M5,12H19M5,17H19</Geometry>

        <Style x:Key="ChromeIconButtonStyle" TargetType="Button" BasedOn="{StaticResource ChromeButtonStyle}">
            <Setter Property="IsEnabled" Value="False"/>
        </Style>

        <SolidColorBrush x:Key="SideButtonFaceBrush" Color="#FF2C2C2E"/>

        <DropShadowEffect x:Key="ChromeDropShadow"
                          Color="#000000"
                          BlurRadius="24"
                          ShadowDepth="8"
                          Direction="270"
                          Opacity="0.28"/>

        <Style x:Key="SideHardwareButtonLeftStyle" TargetType="Button">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Height" Value="76.5"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="IsEnabled" Value="False"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{StaticResource SideButtonFaceBrush}"
                                CornerRadius="3,0,0,3"
                                BorderBrush="#FF080808"
                                BorderThickness="1,1,0,1"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="PressOffset" X="0"/>
                            </Border.RenderTransform>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PressOffset"
                                                             Storyboard.TargetProperty="X"
                                                             To="2.5"
                                                             Duration="0:0:0.07"
                                                             FillBehavior="HoldEnd"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PressOffset"
                                                             Storyboard.TargetProperty="X"
                                                             To="0"
                                                             Duration="0:0:0.12"
                                                             FillBehavior="HoldEnd"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SideHardwareButtonRightStyle" TargetType="Button" BasedOn="{StaticResource SideHardwareButtonLeftStyle}">
            <Setter Property="Height" Value="102"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{StaticResource SideButtonFaceBrush}"
                                CornerRadius="0,3,3,0"
                                BorderBrush="#FF080808"
                                BorderThickness="0,1,1,1"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="PressOffset" X="0"/>
                            </Border.RenderTransform>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PressOffset"
                                                             Storyboard.TargetProperty="X"
                                                             To="-2.5"
                                                             Duration="0:0:0.07"
                                                             FillBehavior="HoldEnd"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PressOffset"
                                                             Storyboard.TargetProperty="X"
                                                             To="0"
                                                             Duration="0:0:0.12"
                                                             FillBehavior="HoldEnd"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>



    <Grid x:Name="RootGrid" ClipToBounds="False">

        <Grid x:Name="ChromeHoverRegion" ClipToBounds="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="TitleBarHitZone"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Panel.ZIndex="0"
                    Background="#01000000"
                    MouseEnter="TitleBarHitZone_MouseEnter"
                    MouseLeave="TitleBarHitZone_MouseLeave"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>

            <Grid Grid.Row="0" Height="52" Panel.ZIndex="1" ClipToBounds="False">
                <Border x:Name="TitleBarChrome"
                        Opacity="0"
                        Background="{StaticResource ChromeBackgroundBrush}"
                        Padding="12,8"
                        Effect="{StaticResource ChromeDropShadow}"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock x:Name="DeviceTitleText"
                                       Text="Screen Mirroring"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock x:Name="DeviceSubtitleText"
                                       Text="Discovering…"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="HomeButton"
                                    Style="{StaticResource ChromeIconButtonStyle}"
                                    Tag="4"
                                    Click="HardwareKeyButton_Click">
                                <Viewbox Width="15" Height="15">
                                    <Path Data="{StaticResource HomeButtonIconGeometry}"
                                          Fill="White"
                                          Stretch="Uniform"/>
                                </Viewbox>
                            </Button>
                            <Button x:Name="MenuButton"
                                    Style="{StaticResource ChromeIconButtonStyle}"
                                    Tag="5"
                                    Click="HardwareKeyButton_Click">
                                <Viewbox Width="15" Height="15">
                                    <Path Data="{StaticResource MenuButtonIconGeometry}"
                                          Stroke="White"
                                          StrokeThickness="1.6"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Stretch="Uniform"/>
                                </Viewbox>
                            </Button>
                            <Button x:Name="RotateButton"
                                    Style="{StaticResource ChromeButtonStyle}"
                                    Content="↻"
                                    Visibility="Collapsed"
                                    Click="RotateButton_Click"/>
                            <Button Style="{StaticResource ChromeButtonStyle}"
                                    Content="—"
                                    Click="MinimizeButton_Click"/>
                            <Button Style="{StaticResource ChromeButtonStyle}"
                                    Content="✕"
                                    Click="CloseButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" ClipToBounds="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Right">
                        <Button x:Name="VolumeUpButton"
                                Style="{StaticResource SideHardwareButtonLeftStyle}"
                                Tag="1"
                                Click="HardwareKeyButton_Click"/>
                        <Button x:Name="VolumeDownButton"
                                Style="{StaticResource SideHardwareButtonLeftStyle}"
                                Tag="2"
                                Margin="0,7,0,0"
                                Click="HardwareKeyButton_Click"/>
                    </StackPanel>
                </Grid>

                <Border x:Name="ViewerShell"
                        Grid.Column="1"
                        Background="#FF101012"
                        SnapsToDevicePixels="True"
                        Effect="{StaticResource ChromeDropShadow}">

                <Border x:Name="ScreenClip"

                        Background="Black">

                    <Grid x:Name="ScreenHost">

                        <Viewbox x:Name="ScreenViewbox"

                                 Stretch="Uniform">

                            <Grid x:Name="FrameHost"

                                  RenderTransformOrigin="0.5,0.5">

                                <Grid.RenderTransform>

                                    <RotateTransform x:Name="ViewRotationTransform" Angle="0"/>

                                </Grid.RenderTransform>

                                <Image x:Name="FrameImage"

                                       Stretch="Fill"

                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>

                            </Grid>

                        </Viewbox>



                        <Grid x:Name="PointerInputLayer"
                              Background="Transparent"
                              MouseMove="FrameImage_MouseMove"
                              MouseLeave="PointerInputLayer_MouseLeave"
                              MouseLeftButtonDown="FrameImage_MouseButton"
                              MouseLeftButtonUp="FrameImage_MouseButton"
                              MouseRightButtonDown="FrameImage_MouseButton"
                              MouseRightButtonUp="FrameImage_MouseButton"
                              MouseWheel="FrameImage_MouseWheel"/>



                        <Grid x:Name="OverlayPanel"

                              Background="#CC000000">

                            <StackPanel VerticalAlignment="Center"

                                        HorizontalAlignment="Center"

                                        Margin="24">

                                <TextBlock Text="Screen Mirroring"

                                           FontSize="22"

                                           FontWeight="SemiBold"

                                           Foreground="White"

                                           HorizontalAlignment="Center"/>

                                <TextBlock x:Name="StatusText"

                                           Margin="0,12,0,0"

                                           Text="Searching for devices…"

                                           TextWrapping="Wrap"

                                           TextAlignment="Center"

                                           Foreground="{StaticResource MutedTextBrush}"/>

                                <ProgressBar x:Name="BusyIndicator"

                                             Margin="0,18,0,0"

                                             Height="4"

                                             IsIndeterminate="True"

                                             Foreground="{StaticResource AccentBrush}"

                                             Background="#33FFFFFF"

                                             BorderThickness="0"/>

                            </StackPanel>

                        </Grid>

                    </Grid>

                </Border>

            </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>
                    <Button x:Name="SideButtonButton"
                            Grid.Row="1"
                            Style="{StaticResource SideHardwareButtonRightStyle}"
                            Tag="3"
                            Click="HardwareKeyButton_Click"/>
                </Grid>
            </Grid>

        </Grid>

    </Grid>

</Window>


