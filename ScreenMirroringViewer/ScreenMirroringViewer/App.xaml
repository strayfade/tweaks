<Application x:Class="ScreenMirroringViewer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="ChromeBackgroundBrush" Color="#FF1C1C1E"/>
        <SolidColorBrush x:Key="DeviceBezelBrush" Color="#FF1C1C1E"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF0A84FF"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#99FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFFFFFFF"/>
        <FontFamily x:Key="UIFont">Segoe UI Variable Text, Segoe UI</FontFamily>
    </Application.Resources>
</Application>
