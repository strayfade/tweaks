# Copy to one of (first match wins):
#   ./theos-device.env next to a tweak,  OR  ./theos-device.env at repo root,  OR  ~/.theos-device.env
#
# Never commit the real file with your password.

export THEOS_DEVICE_IP="192.168.1.23"
export THEOS_DEVICE_USER="mobile"
export THEOS_DEVICE_SUDO_PASSWORD="your-alpine-here"

# Optional: multiplex SSH so scp + install reuse one connection (default on).
# export THEOS_SSH_MUX=0
